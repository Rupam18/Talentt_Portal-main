# Maven Start Up Batch script
#
# Required ENV vars:
# ------------------
#   JAVA_HOME - location of a JDK home dir
#   M2_HOME - location of maven2's installed home dir
#   MAVEN_OPTS - parameters passed to the Java VM when running Maven
#     e.g. to debug Maven itself, use
#       set MAVEN_OPTS=-Xdebug -Xrunjdwp:transport=dt_socket,server=y,suspend=y,address=8000
#   MAVEN_SKIP_RC - flag to disable loading of mavenrc files
# ----------------------------------------------------------------------------

if [ -z "$MAVEN_SKIP_RC" ] ; then

  if [ -f /usr/local/etc/mavenrc ] ; then
    . /usr/local/etc/mavenrc
  fi

  if [ -f /etc/mavenrc ] ; then
    . /etc/mavenrc
  fi

  if [ -f "$HOME/.mavenrc" ] ; then
    . "$HOME/.mavenrc"
  fi

fi

# OS specific support.  $var _must_ be set to either true or false.
cygwin=false;
darwin=false;
mingw=false
case "`uname`" in
CYGWIN*) cygwin=true ;;
MINGW*) mingw=true;;
Darwin*) darwin=true;;
esac

# For Cygwin, ensure paths are in UNIX format before anything is touched
if $cygwin ; then
  [ -n "$M2_HOME" ] &&
    M2_HOME=`cygpath --unix "$M2_HOME"`
  [ -n "$JAVA_HOME" ] &&
    JAVA_HOME=`cygpath --unix "$JAVA_HOME"`
  [ -n "$CLASSPATH" ] &&
    CLASSPATH=`cygpath --path --unix "$CLASSPATH"`
fi

# For Mingw, ensure paths are in UNIX format before anything is touched
if $mingw ; then
  [ -n "$M2_HOME" ] &&
    M2_HOME="`(cd "$M2_HOME"; pwd)`"
  [ -n "$JAVA_HOME" ] &&
    JAVA_HOME="`(cd "$JAVA_HOME"; pwd)`"
fi

if [ -z "$JAVA_HOME" ] ; then
  JAVACMD=`which java`
else
  JAVACMD="$JAVA_HOME/bin/java"
fi

if [ ! -x "$JAVACMD" ] ; then
  echo "Error: JAVA_HOME is not defined correctly." >&2
  echo "  We cannot execute $JAVACMD" >&2
  exit 1
fi

CLASSPATH=$APP_HOME/$(echo "$APP_WAR_FILE" | sed 's/\(.*\)\.jar/\1.jar\/WEB-INF\/lib/')
CLASSPATH=$CLASSPATH:$APP_HOME/$(echo "$APP_WAR_FILE" | sed 's/\(.*\)\.jar/\1.jar\/WEB-INF\/classes/')

# For Cygwin, switch paths to Windows format before running java
if $cygwin ; then
  [ -n "$M2_HOME" ] &&
    M2_HOME=`cygpath --path --windows "$M2_HOME"`
  [ -n "$JAVA_HOME" ] &&
    JAVA_HOME=`cygpath --path --windows "$JAVA_HOME"`
  [ -n "$CLASSPATH" ] &&
    CLASSPATH=`cygpath --path --windows "$CLASSPATH"`
  JAVACMD=`cygpath --unix "$JAVACMD"`
fi

# Provide a "standardized" way to retrieve the CLI args that will
# work with both Windows and non-Windows executions.
MAVEN_CMD_LINE_ARGS="$MAVEN_CONFIG $@"
export MAVEN_CMD_LINE_ARGS

WRAPPER_LAUNCHER=org.apache.maven.wrapper.MavenWrapperMain

# start MAVEN_OPTS
if [ -z "$MAVEN_OPTS" ] ; then
  MAVEN_OPTS="-Xmx1024m"
fi

# start MAVEN_CMD_LINE_ARGS
if [ -z "$MAVEN_CMD_LINE_ARGS" ] ; then
  MAVEN_CMD_LINE_ARGS="$@"
fi

# start MAVEN_PROJECT_BASEDIR
if [ -z "$MAVEN_PROJECT_BASEDIR" ] ; then
  MAVEN_PROJECT_BASEDIR=$(pwd)
fi

# resolves WRAPPER_LAUNCHER
WRAPPER_LAUNCHER_JAR="$MAVEN_PROJECT_BASEDIR/.mvn/wrapper/maven-wrapper.jar"
if [ -f "$WRAPPER_LAUNCHER_JAR" ] ; then
  true # placeholder for empty block
else
  echo "ERROR: Maven wrapper JAR not found at $WRAPPER_LAUNCHER_JAR" >&2
  exit 1
fi

# echo "Using Maven wrapper at $WRAPPER_LAUNCHER_JAR"
exec "$JAVACMD" \
  $MAVEN_OPTS \
  -classpath "$WRAPPER_LAUNCHER_JAR" \
  "-Dmaven.home=$MAVEN_PROJECT_BASEDIR/.mvn/wrapper" \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECT_BASEDIR" \
  $WRAPPER_LAUNCHER \
  $MAVEN_CMD_LINE_ARGS
exit $?
